generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  parentName    String
  phone         String    @unique
  password      String?
  qrCode        String    @unique
  lineUserId    String?
  coinExpiryOverride DateTime?
  children      Child[]
  coinPackages  CoinPackage[]
  borrowRecords BorrowRecord[]
  topUpRequests TopUpRequest[]
  expiryLogs    ExpiryLog[]
  classBookings  ClassBooking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ExpiryLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  previousDate  DateTime?
  newDate       DateTime
  note          String?
  performedBy   String
  createdAt     DateTime  @default(now())
}

model Child {
  id          String    @id @default(cuid())
  name        String
  birthDate   DateTime
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  classBookings ClassBooking[]
  createdAt   DateTime  @default(now())
}

model AdminUser {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        AdminRole @default(ADMIN)
  borrowRecords   BorrowRecord[]
  coinTransactions CoinTransaction[]
  topUpRequests    TopUpRequest[]
  classBookings    ClassBooking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

model ShopInfo {
  id               String   @id @default(cuid())
  shopName         String   @default("Namoland")
  bankName         String?
  accountNumber    String?
  accountName      String?
  note             String?
  scheduleImageUrl String?
  updatedAt        DateTime @updatedAt
}

model TopUpRequest {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  packageType   String
  coins         Int
  amount        Decimal
  status        TopUpStatus  @default(PENDING)
  slipNote      String?
  adminNote     String?
  processedById String?
  processedBy   AdminUser?   @relation(fields: [processedById], references: [id])
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
}

model CoinPackage {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  packageType   String
  totalCoins    Int
  remainingCoins Int
  pricePaid     Decimal
  bonusAmount   Decimal   @default(0)
  firstUsedAt   DateTime?
  expiresAt     DateTime?
  isExpired     Boolean   @default(false)
  isExtended    Boolean   @default(false)
  extendedAt    DateTime?
  extendedBy    String?
  note          String?
  paymentMethod String?
  transactions  CoinTransaction[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CoinTransaction {
  id            String           @id @default(cuid())
  packageId     String
  package       CoinPackage      @relation(fields: [packageId], references: [id])
  type          CoinTransactionType
  coinsUsed     Int
  className     String?
  classHours    Decimal?
  description   String?
  borrowRecordId String?
  processedById  String
  processedBy    AdminUser       @relation(fields: [processedById], references: [id])
  createdAt     DateTime         @default(now())
}

enum CoinTransactionType {
  CLASS_FEE
  BOOK_RENTAL
  BOOK_DEPOSIT
  BOOK_DEPOSIT_RETURN
  BOOK_LATE_FEE
  BOOK_DAMAGE_FEE
  DEPOSIT_FORFEIT
  EXPIRED
  ADJUSTMENT
  EXTENSION
}

model Book {
  id          String    @id @default(cuid())
  title       String
  qrCode      String    @unique
  isbn        String?
  category    String?
  ageRange    String?
  coverImage  String?
  youtubeUrl  String?
  rentalCost  Int       @default(1)
  isAvailable Boolean   @default(true)
  isActive    Boolean   @default(true)
  borrowItems BorrowItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BorrowRecord {
  id            String        @id @default(cuid())
  code          String        @unique
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  status        BorrowStatus  @default(BORROWED)
  borrowDate    DateTime      @default(now())
  dueDate       DateTime
  returnDate    DateTime?
  depositCoins  Int           @default(5)
  rentalCoins   Int           @default(1)
  lateFeeCoins  Int           @default(0)
  damageFeeCoins Int          @default(0)
  depositReturned Boolean     @default(false)
  depositForfeited Boolean    @default(false)
  processedById  String?
  processedBy    AdminUser?  @relation(fields: [processedById], references: [id])
  returnedById   String?
  items          BorrowItem[]
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum BorrowStatus {
  RESERVED
  BORROWED
  RETURNED
  OVERDUE
  FORFEITED
  CANCELLED
}

model BorrowItem {
  id            String    @id @default(cuid())
  borrowRecordId String
  borrowRecord  BorrowRecord @relation(fields: [borrowRecordId], references: [id])
  bookId        String
  book          Book      @relation(fields: [bookId], references: [id])
  isDamaged     Boolean   @default(false)
  damageNote    String?
  returned      Boolean   @default(false)
  returnedAt    DateTime?
}

model PackageConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  coins     Int
  price     Int
  bonus     Int      @default(0)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityConfig {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  coins       Int      @default(1)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClassSchedule {
  id        String       @id @default(cuid())
  title     String?
  theme     String?
  startDate DateTime
  endDate   DateTime
  entries   ClassEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ClassEntry {
  id         String        @id @default(cuid())
  scheduleId String
  schedule   ClassSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  title      String
  sortOrder  Int           @default(0)
  bookings   ClassBooking[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ClassBooking {
  id            String        @id @default(cuid())
  classEntryId  String
  classEntry    ClassEntry    @relation(fields: [classEntryId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  childId       String?
  child         Child?        @relation(fields: [childId], references: [id])
  coinsCharged  Int           @default(0)
  status        BookingStatus @default(BOOKED)
  note          String?
  bookedById    String
  bookedBy      AdminUser     @relation(fields: [bookedById], references: [id])
  checkedInAt   DateTime?
  createdAt     DateTime      @default(now())
}

enum BookingStatus {
  BOOKED
  CHECKED_IN
  CANCELLED
  NO_SHOW
}
